{
  "name": "learnframe",
  "version": "0.1.4",
  "private": false,
  "type": "module",
  "description": "YouTube-first learning SDK for low-cost transcript extraction, study artifacts, timestamped QA, and embeddable video learning surfaces.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "bin": {
    "learnframe": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
